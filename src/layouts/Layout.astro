---
import '../styles/global.css';
interface Props {
  title?: string;
}
const { title = 'Etsy Scout' } = Astro.props;
---
<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <!-- Open Graph -->
    <meta property="og:title" content="Etsy Scout" />
    <meta property="og:description" content="Market research for 3D print &amp; laser cut Etsy sellers. Search live listings, analyse price distribution and spot popular products." />
    <meta property="og:image" content="https://etsyscout.netlify.app/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content="https://etsyscout.netlify.app/" />
    <meta property="og:type" content="website" />
    <meta property="fb:app_id" content="811269275316635" />
    <!-- Apply saved theme before paint to prevent flash -->
    <script is:inline>
      const saved = localStorage.getItem('theme');
      if (saved === 'light') {
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="min-h-screen bg-[#FAF7F4] dark:bg-[#0f1117] text-[#222222] dark:text-slate-200 transition-colors duration-200 flex flex-col">
    <div class="flex-1">
      <slot />
    </div>
    <footer class="bg-[#243B55] px-6 py-4 mt-8 flex items-center justify-between text-xs text-[#a0b4c8]">
      <span>v1.11.0</span>
      <a
        href="https://github.com/JavierIOM/etsyscout"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 hover:text-white transition-colors"
      >
        <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        github.com/JavierIOM/etsyscout
      </a>
    </footer>
  </body>
</html>
