---
import Layout from '../layouts/Layout.astro';
import * as cheerio from 'cheerio';

const ETSY_API_KEY = import.meta.env.ETSY_API_KEY;
const SCRAPE_DO_TOKEN = import.meta.env.SCRAPE_DO_TOKEN;

interface EtsyListing {
  listing_id: number;
  title: string;
  price: { amount: number; divisor: number; currency_code: string };
  num_favorers: number;
  views: number;
  url: string;
  quantity: number;
  image?: string;
}

interface SearchResult {
  listings: EtsyListing[];
  totalCount: number;
  error?: string;
  source?: 'api' | 'scrape';
}

const query = Astro.url.searchParams.get('q') ?? '';
const sortBy = Astro.url.searchParams.get('sort') ?? 'score';
const minPrice = Astro.url.searchParams.get('min') ?? '';
const maxPrice = Astro.url.searchParams.get('max') ?? '';

const QUICK_SEARCHES = [
  '3d printed',
  'laser cut',
  'laser engraved',
  'personalised gift',
  'custom name sign',
  'wall art',
  'cable organizer',
  'planter',
  'keychain',
  'coaster set',
];

let results: SearchResult = { listings: [], totalCount: 0 };

if (query && ETSY_API_KEY) {
  try {
    const params = new URLSearchParams({
      keywords: query,
      limit: '100',
      sort_on: sortBy,
      sort_order: 'desc',
      ...(minPrice && { min_price: minPrice }),
      ...(maxPrice && { max_price: maxPrice }),
    });

    const res = await fetch(
      `https://openapi.etsy.com/v3/application/listings/active?${params}`,
      { headers: { 'x-api-key': ETSY_API_KEY } }
    );

    if (!res.ok) {
      const body = await res.text();
      results.error = `Etsy API error ${res.status}: ${body}`;
    } else {
      const data = await res.json();
      results.listings = data.results ?? [];
      results.totalCount = data.count ?? 0;
    }
  } catch (e) {
    results.error = e instanceof Error ? e.message : 'Unknown error';
  }
} else if (query && SCRAPE_DO_TOKEN) {
  // scrape.do fallback — used while Etsy API key is pending
  try {
    const searchUrl = `https://www.etsy.com/uk/search?q=${encodeURIComponent(query)}&ref=search_bar`;
    // render=true loads the full JS-rendered page for more results; super=true uses residential proxies
    const proxyUrl = `http://api.scrape.do/?token=${SCRAPE_DO_TOKEN}&url=${encodeURIComponent(searchUrl)}&render=true&super=true`;

    const res = await fetch(proxyUrl);

    if (!res.ok) {
      results.error = `Scrape error ${res.status} — try again shortly.`;
    } else {
      const html = await res.text();
      const $ = cheerio.load(html);
      const listings: EtsyListing[] = [];

      const seenUrls = new Set<string>();

      // JSON-LD structured data — process all matching script tags
      $('script[type="application/ld+json"]').each((_, el) => {
        try {
          const data = JSON.parse($(el).html() ?? '');
          if (data['@type'] === 'ItemList' && Array.isArray(data.itemListElement)) {
            for (const item of data.itemListElement) {
              const product = item.item ?? item;
              const rawPrice = product.offers?.price ?? product.offers?.lowPrice;
              const url = product.url ?? product['@id'];
              const title = product.name;
              if (title && url && rawPrice != null && !seenUrls.has(url)) {
                const priceNum = parseFloat(String(rawPrice));
                if (!isNaN(priceNum)) {
                  seenUrls.add(url);
                  const rawImage = product.image;
                  const image = Array.isArray(rawImage) ? rawImage[0] : rawImage;
                  listings.push({
                    listing_id: listings.length,
                    title,
                    price: { amount: Math.round(priceNum * 100), divisor: 100, currency_code: 'GBP' },
                    num_favorers: 0,
                    views: 0,
                    url,
                    quantity: 1,
                    image: typeof image === 'string' ? image : undefined,
                  });
                }
              }
            }
          }
        } catch {}
      });

      // DOM scrape — always runs and fills in anything JSON-LD missed
      $('a[href*="/listing/"]').each((_, el) => {
        const href = $(el).attr('href');
        if (!href) return;
        const fullUrl = href.startsWith('http') ? href : `https://www.etsy.com${href}`;
        // Normalise — strip query string for dedup
        const urlKey = fullUrl.split('?')[0];
        if (seenUrls.has(urlKey)) return;
        const title = $(el).find('h3, p').first().text().trim() || $(el).text().trim();
        if (!title || title.length < 5) return;
        const card = $(el).closest('[data-listing-id]');
        const priceText = card.find('[class*="price"]').first().text().trim()
          || $(el).find('[class*="price"]').first().text().trim();
        const priceMatch = priceText.match(/[\d,.]+/);
        const priceNum = priceMatch ? parseFloat(priceMatch[0].replace(',', '')) : 0;
        // Image — prefer data-src (lazy-loaded) then src, from etsystatic CDN
        const imgEl = card.find('img[src*="etsystatic"], img[data-src*="etsystatic"]').first();
        const image = imgEl.attr('data-src') || imgEl.attr('src');
        seenUrls.add(urlKey);
        listings.push({
          listing_id: listings.length,
          title,
          price: { amount: Math.round(priceNum * 100), divisor: 100, currency_code: 'GBP' },
          num_favorers: 0,
          views: 0,
          url: fullUrl,
          quantity: 1,
          image,
        });
      });

      if (listings.length > 0) {
        results.listings = listings;
        results.totalCount = listings.length;
        results.source = 'scrape';
      } else {
        results.error = 'Could not extract listings from Etsy — page structure may have changed.';
      }
    }
  } catch (e) {
    results.error = e instanceof Error ? e.message : 'Scrape error';
  }
} else if (query) {
  results.error = 'No ETSY_API_KEY or SCRAPE_DO_TOKEN environment variable is set.';
}

// ---- Stats ----------------------------------------------------------------
function getPrice(l: EtsyListing) {
  return l.price.amount / l.price.divisor;
}

const prices = results.listings.map(getPrice);
const avgPrice = prices.length ? prices.reduce((a, b) => a + b, 0) / prices.length : 0;
const minPriceFound = prices.length ? Math.min(...prices) : 0;
const maxPriceFound = prices.length ? Math.max(...prices) : 0;
const avgFavorites = results.listings.length
  ? results.listings.reduce((a, b) => a + b.num_favorers, 0) / results.listings.length
  : 0;

// ---- Price histogram -------------------------------------------------------
function buildHistogram(prices: number[], buckets = 8) {
  if (!prices.length) return [];
  const min = Math.min(...prices);
  const max = Math.max(...prices);
  const range = max - min || 1;
  const step = range / buckets;
  const bars: { label: string; count: number; pct: number }[] = Array.from({ length: buckets }, (_, i) => ({
    label: `£${(min + i * step).toFixed(0)}`,
    count: 0,
    pct: 0,
  }));
  for (const p of prices) {
    const idx = Math.min(Math.floor((p - min) / step), buckets - 1);
    bars[idx].count++;
  }
  const maxCount = Math.max(...bars.map((b) => b.count), 1);
  bars.forEach((b) => (b.pct = (b.count / maxCount) * 100));
  return bars;
}

const histogram = buildHistogram(prices);

// ---- Top listings by favorites --------------------------------------------
const topListings = [...results.listings]
  .sort((a, b) => b.num_favorers - a.num_favorers)
  .slice(0, 25);

const fmt = (n: number) => new Intl.NumberFormat('en-GB', { style: 'currency', currency: 'GBP' }).format(n);
---

<Layout title={query ? `Etsy Scout — ${query}` : 'Etsy Scout'}>
  <!-- Header -->
  <header class="bg-white dark:bg-slate-900 border-b border-[#D9D9D9] dark:border-slate-800 px-6 py-5 flex items-center justify-between gap-4 no-print">
    <div class="flex items-center gap-3">
      <!-- Logo -->
      <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect width="36" height="36" rx="8" fill="#F56400"/>
        <circle cx="15.5" cy="15.5" r="7" stroke="white" stroke-width="2.5" fill="none"/>
        <line x1="20.5" y1="20.5" x2="27" y2="27" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="12.5" y1="15.5" x2="18.5" y2="15.5" stroke="white" stroke-width="2" stroke-linecap="round"/>
        <line x1="15.5" y1="12.5" x2="15.5" y2="18.5" stroke="white" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <div>
        <h1 class="text-lg font-bold tracking-tight text-[#222222] dark:text-white">Etsy Scout</h1>
        <p class="text-xs text-[#595959] dark:text-slate-400">Market research for 3D print &amp; laser cut sellers</p>
      </div>
    </div>
    <!-- Theme toggle -->
    <button
      id="theme-toggle"
      aria-label="Toggle light/dark theme"
      class="p-2 rounded border border-slate-200 dark:border-slate-700 text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:border-slate-400 dark:hover:border-slate-500 transition-colors text-xs font-medium"
    >
      <span class="dark:hidden">Dark</span>
      <span class="hidden dark:inline">Light</span>
    </button>
  </header>

  <main class="max-w-6xl mx-auto px-6 py-8 space-y-8">

    <!-- Search form -->
    <form method="GET" class="space-y-4 no-print">
      <div class="flex gap-3">
        <label for="q" class="sr-only">Search Etsy listings</label>
        <input
          type="text"
          id="q"
          name="q"
          value={query}
          placeholder="Search Etsy listings..."
          class="flex-1 bg-white dark:bg-slate-900 border border-slate-300/70 dark:border-slate-700 rounded px-4 py-2.5 text-[#222222] dark:text-white placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:border-orange-500 focus:ring-1 focus:ring-orange-500 text-sm"
          autofocus
        />
        <button
          type="submit"
          class="bg-orange-600 hover:bg-orange-500 text-white font-semibold px-6 py-2.5 rounded text-sm transition-colors"
        >
          Search
        </button>
      </div>

      <!-- Filters row -->
      <div class="flex flex-wrap gap-4 items-center text-sm">
        <div class="flex items-center gap-2">
          <label for="sort" class="text-slate-500 dark:text-slate-400 text-xs uppercase tracking-wider">Sort</label>
          <select id="sort" name="sort" class="bg-white dark:bg-slate-900 border border-slate-300/70 dark:border-slate-700 rounded px-3 py-1.5 text-[#222222] dark:text-white text-sm focus:outline-none focus:border-orange-500 focus:ring-1 focus:ring-orange-500">
            <option value="score" selected={sortBy === 'score'}>Relevance</option>
            <option value="created" selected={sortBy === 'created'}>Newest</option>
            <option value="price" selected={sortBy === 'price'}>Price</option>
          </select>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-slate-500 dark:text-slate-400 text-xs uppercase tracking-wider">Price</span>
          <span class="text-slate-400 dark:text-slate-500 text-sm">£</span>
          <label for="min" class="sr-only">Minimum price</label>
          <input
            type="number"
            id="min"
            name="min"
            value={minPrice}
            placeholder="Min"
            min="0"
            class="w-20 bg-white dark:bg-slate-900 border border-slate-300/70 dark:border-slate-700 rounded px-2 py-1.5 text-[#222222] dark:text-white text-sm focus:outline-none focus:border-orange-500 focus:ring-1 focus:ring-orange-500"
          />
          <span class="text-slate-400 dark:text-slate-600">—</span>
          <span class="text-slate-400 dark:text-slate-500 text-sm">£</span>
          <label for="max" class="sr-only">Maximum price</label>
          <input
            type="number"
            id="max"
            name="max"
            value={maxPrice}
            placeholder="Max"
            min="0"
            class="w-20 bg-white dark:bg-slate-900 border border-slate-300/70 dark:border-slate-700 rounded px-2 py-1.5 text-[#222222] dark:text-white text-sm focus:outline-none focus:border-orange-500 focus:ring-1 focus:ring-orange-500"
          />
        </div>
      </div>
    </form>

    <!-- Quick search chips -->
    <div class="flex flex-wrap gap-2 no-print">
      {QUICK_SEARCHES.map((term) => (
        <a
          href={`/?q=${encodeURIComponent(term)}`}
          class={`px-3 py-1 rounded-full text-xs border transition-colors ${
            query === term
              ? 'bg-orange-600 border-orange-600 text-white'
              : 'border-slate-300/70 dark:border-slate-700 text-[#595959] dark:text-slate-400 hover:border-slate-400 dark:hover:border-slate-500 hover:text-[#222222] dark:hover:text-slate-300'
          }`}
        >
          {term}
        </a>
      ))}
    </div>

    <!-- Error state -->
    {results.error && (
      <div class="bg-red-50 dark:bg-red-900/30 border border-red-300 dark:border-red-700 rounded p-4 text-red-700 dark:text-red-300 text-sm">
        {results.error}
      </div>
    )}

    <!-- Results -->
    {results.listings.length > 0 && (
      <div class="space-y-8">

        <!-- Print-only header (hidden on screen) -->
        <div class="hidden print:block mb-4">
          <h1 class="text-2xl font-bold">Etsy Scout — Market Research Report</h1>
          <p class="text-sm text-gray-500 mt-1">
            Search: <strong>{query}</strong>
            {sortBy !== 'score' && <> &middot; Sort: {sortBy}</>}
            {minPrice && <> &middot; Min: £{minPrice}</>}
            {maxPrice && <> &middot; Max: £{maxPrice}</>}
            &middot; {new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
          </p>
        </div>

        <!-- Export PDF button -->
        <div class="flex justify-end no-print">
          <button
            id="export-pdf"
            type="button"
            class="flex items-center gap-2 px-4 py-2 rounded border border-slate-300/70 dark:border-slate-700 text-sm text-[#595959] dark:text-slate-400 hover:border-orange-500 hover:text-orange-600 dark:hover:text-orange-400 transition-colors"
          >
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M3 1h7l3 3v10a1 1 0 01-1 1H3a1 1 0 01-1-1V2a1 1 0 011-1z" stroke="currentColor" stroke-width="1.4" fill="none"/>
              <path d="M10 1v3h3M8 7v5M5.5 9.5L8 12l2.5-2.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Export PDF
          </button>
        </div>

        <!-- Scrape mode notice -->
        {results.source === 'scrape' && (
          <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-300 dark:border-amber-700 rounded px-4 py-2.5 text-xs text-amber-700 dark:text-amber-400 no-print">
            Using web scrape fallback — favorites and views are unavailable. Awaiting Etsy API key for full data.
          </div>
        )}

        <!-- Stats cards -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 print-section">
          {[
            { label: 'Listings found', value: results.totalCount.toLocaleString() },
            { label: 'Avg price', value: fmt(avgPrice) },
            { label: 'Price range', value: `${fmt(minPriceFound)} – ${fmt(maxPriceFound)}` },
            ...(results.source !== 'scrape' ? [{ label: 'Avg favorites', value: Math.round(avgFavorites).toLocaleString() }] : []),
          ].map(({ label, value }) => (
            <div class="stat-card bg-white dark:bg-slate-900 border border-[#D9D9D9] dark:border-slate-800 border-t-2 border-t-orange-600 rounded p-4">
              <p class="text-xs text-slate-400 dark:text-slate-500 uppercase tracking-wider mb-1">{label}</p>
              <p class="text-xl font-bold text-[#222222] dark:text-white">{value}</p>
            </div>
          ))}
        </div>

        <!-- Price histogram -->
        <div class="bg-white dark:bg-slate-900 border border-[#D9D9D9] dark:border-slate-800 rounded p-6">
          <h2 class="text-sm font-semibold text-[#595959] dark:text-slate-300 uppercase tracking-wider mb-6">Price Distribution</h2>
          <div class="flex items-end gap-2" style="height: 10rem;">
            {histogram.map((bar) => (
              <div class="flex-1 flex flex-col items-center justify-end gap-1 h-full">
                <span class="text-xs text-slate-400 dark:text-slate-500 leading-none">{bar.count}</span>
                <div
                  class="histogram-bar w-full bg-orange-600 rounded-t transition-all"
                  style={`height: ${Math.max(bar.pct, 2)}%`}
                ></div>
                <span class="text-xs text-slate-400 dark:text-slate-500 truncate w-full text-center leading-none pt-1">{bar.label}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Top listings table -->
        <div class="bg-white dark:bg-slate-900 border border-[#D9D9D9] dark:border-slate-800 rounded overflow-hidden">
          <div class="px-6 py-4 border-b border-[#D9D9D9] dark:border-slate-800">
            <h2 class="text-sm font-semibold text-[#595959] dark:text-slate-300 uppercase tracking-wider">
              Top {topListings.length} Listings{results.source !== 'scrape' ? ' by Favorites' : ''}
            </h2>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="border-b border-[#D9D9D9] dark:border-slate-800">
                <tr class="text-left">
                  <th class="px-3 py-3 w-14 print:hidden"></th>
                  <th class="px-6 py-3 text-xs text-slate-400 dark:text-slate-500 font-medium uppercase tracking-wider">Title</th>
                  <th class="px-6 py-3 text-xs text-slate-400 dark:text-slate-500 font-medium uppercase tracking-wider text-right">Price</th>
                  {results.source !== 'scrape' && (
                    <>
                      <th class="px-6 py-3 text-xs text-slate-400 dark:text-slate-500 font-medium uppercase tracking-wider text-right">Favorites</th>
                      <th class="px-6 py-3 text-xs text-slate-400 dark:text-slate-500 font-medium uppercase tracking-wider text-right">Views</th>
                    </>
                  )}
                </tr>
              </thead>
              <tbody class="divide-y divide-[#D9D9D9] dark:divide-slate-800">
                {topListings.map((listing, i) => (
                  <tr class="hover:bg-[#FAF7F4] dark:hover:bg-slate-800/50 transition-colors">
                    <td class="px-3 py-2 print:hidden">
                      <a href={listing.url} target="_blank" rel="noopener noreferrer" tabindex="-1">
                        {listing.image ? (
                          <img
                            src={listing.image}
                            alt=""
                            width="48"
                            height="48"
                            class="w-12 h-12 object-cover rounded border border-[#D9D9D9] dark:border-slate-700"
                            loading="lazy"
                          />
                        ) : (
                          <div class="w-12 h-12 rounded border border-[#D9D9D9] dark:border-slate-700 bg-slate-100 dark:bg-slate-800"></div>
                        )}
                      </a>
                    </td>
                    <td class="px-6 py-3">
                      <a
                        href={listing.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        title={listing.title}
                        class="text-slate-700 dark:text-slate-200 hover:text-orange-600 dark:hover:text-orange-400 transition-colors line-clamp-2 leading-snug"
                      >
                        <span class="text-slate-400 dark:text-slate-600 mr-2 tabular-nums">{i + 1}.</span>
                        {listing.title}
                      </a>
                    </td>
                    <td class="px-6 py-3 text-right font-mono font-semibold text-green-600 dark:text-green-400">
                      {fmt(getPrice(listing))}
                    </td>
                    {results.source !== 'scrape' && (
                      <>
                        <td class="px-6 py-3 text-right text-[#595959] dark:text-slate-300">
                          {listing.num_favorers.toLocaleString()}
                        </td>
                        <td class="px-6 py-3 text-right text-slate-400 dark:text-slate-500">
                          {listing.views.toLocaleString()}
                        </td>
                      </>
                    )}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

      </div>
    )}

    <!-- Empty state (no query yet) -->
    {!query && (
      <div class="text-center py-16 border border-dashed border-[#D9D9D9] dark:border-slate-800 rounded">
        <p class="text-sm text-[#595959] dark:text-slate-500">Pick a quick search above or type a keyword to scout the market.</p>
        <p class="text-xs text-[#595959] dark:text-slate-700 mt-2">Searches return up to 100 live listings ranked by favorites.</p>
      </div>
    )}

  </main>

  <script>
    const btn = document.getElementById('theme-toggle');
    btn?.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });

    document.getElementById('export-pdf')?.addEventListener('click', () => {
      window.print();
    });
  </script>
</Layout>
